{
  "name": "ege-business",
  "version": "1.0.0",
  "description": "EGE Business — Intelligence Platform",
  "scripts": {
    "dev": "next dev -p 3005",
    "build": "next build && node -e \"const fs=require('fs'),g=require('path');function fix(d){if(!fs.existsSync(d))return;fs.readdirSync(d,{withFileTypes:true}).forEach(e=>{const p=g.join(d,e.name);if(e.isDirectory())fix(p);else if(!e.name.includes('.')){try{const c=fs.readFileSync(p,'utf8');if(c.trim().startsWith('{'))fs.cpSync(p,p+'.json')}catch{}}})};fix('out/api')\"",
    "build:cap": "npm run build && node -e \"const http=require('http');const fs=require('fs');['api/market','api/news'].forEach(p=>{const r=http.get('http://localhost:3005/'+p,res=>{let d='';res.on('data',c=>d+=c);res.on('end',()=>{fs.mkdirSync('out/'+require('path').dirname(p),{recursive:true});fs.writeFileSync('out/'+p+'.json',d);console.log(p+'.json OK')})});r.on('error',()=>console.log(p+' skip'))})\" && npx cap sync ios",
    "start": "next start -p 3005",
    "lint": "next lint",
    "cap:sync": "npx cap sync ios",
    "cap:open": "npx cap open ios",
    "cap:run": "npx cap run ios"
  },
  "keywords": [
    "business",
    "intelligence",
    "management"
  ],
  "author": "EGE Business",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@google/generative-ai": "^0.24.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "@swc/helpers": "0.5.15",
    "browserslist": "^4.28.1",
    "caniuse-lite": "^1.0.30001741",
    "decimal.js": "^10.6.0",
    "echarts": "^6.0.0",
    "framer-motion": "^12.38.0",
    "groq-sdk": "^1.1.1",
    "lucide-react": "^0.577.0",
    "motion-dom": "^12.38.0",
    "next": "^16.2.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^2.12.0",
    "three": "^0.183.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
